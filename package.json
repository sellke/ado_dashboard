{
  "name": "mantine-next-template",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/clean-next-dev.mjs && next dev",
    "dev:clean": "pnpm dev",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm run eslint && pnpm run stylelint",
    "eslint": "next lint",
    "stylelint": "stylelint \"**/*.css\" --cache --allow-empty-input",
    "jest": "jest",
    "jest:watch": "jest --watch",
    "jest:prisma": "jest __tests__/prisma --runInBand",
    "prettier:check": "prettier --check \"**/*.{ts,tsx}\"",
    "prettier:write": "prettier --write \"**/*.{ts,tsx}\"",
    "test": "pnpm run prettier:check && pnpm run lint && pnpm run typecheck && pnpm run jest",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "db:up": "docker-compose up -d postgres",
    "db:down": "docker-compose down",
    "db:reset": "docker-compose down -v && docker-compose up -d postgres",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:push": "prisma db push"
  },
  "dependencies": {
    "@mantine/core": "8.2.1",
    "@mantine/hooks": "8.2.1",
    "@next/bundle-analyzer": "^15.3.3",
    "@prisma/client": "^6.3.0",
    "@tabler/icons-react": "^3.34.0",
    "next": "15.3.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@eslint/js": "^9.29.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.2",
    "@storybook/nextjs": "^8.6.8",
    "@storybook/react": "^8.6.8",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/eslint-plugin-jsx-a11y": "^6",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.11",
    "@types/react": "19.1.8",
    "babel-loader": "^10.0.0",
    "eslint": "^9.29.0",
    "eslint-config-mantine": "^4.0.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "playwright": "^1.58.2",
    "postcss": "^8.5.5",
    "postcss-preset-mantine": "1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.5.3",
    "prisma": "^6.3.0",
    "storybook": "^8.6.8",
    "storybook-dark-mode": "^4.0.2",
    "stylelint": "^16.20.0",
    "stylelint-config-standard-scss": "^15.0.1",
    "ts-jest": "^29.4.0",
    "tsx": "^4.20.3",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.34.0"
  }
}
