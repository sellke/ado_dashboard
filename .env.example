# Database connection (local Docker PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/nextapp?schema=public"

# 32-byte hex key for encrypting saved ADO PATs at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_ENCRYPTION_KEY=""

# Azure DevOps REST API credentials (required for /api/sync/ado)
ADO_ORG="Operations-Innovation"
ADO_PAT="your_ado_pat_here"
